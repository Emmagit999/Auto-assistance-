# Not required here — on first run, open the web UI and paste a free key from
# https://openrouter.ai/keys into the setup screen. This var is only a fallback for
# headless/CI setups that would rather set it via environment than the UI.
OPENROUTER_API_KEY=

# Shown to OpenRouter for their leaderboard/rankings, optional but recommended
OPENROUTER_SITE_URL=https://github.com/
OPENROUTER_APP_NAME=Androg

# Port for the local web chat UI
WEB_PORT=3000

# Max seconds a run/compile step is allowed to take before it's killed
EXEC_TIMEOUT_SECONDS=20
